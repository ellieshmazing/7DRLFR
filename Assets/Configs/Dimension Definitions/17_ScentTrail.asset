  m_Script: {fileID: 11500000, guid: ff60679b078f6a84cafb8f957d07cd55, type: 3}
  m_Name: 17_ScentTrail
  m_EditorClassIdentifier: Assembly-CSharp::TuningDimensionDef
  dimensionName: Scent Trail
  testScenario: Let player stand still 10 seconds, move away, stand still again. Watch
    centipede follow the ghost path. High decayTime = long-lived memory. High sigma
    = blurry wide trail, gradient activates earlier.
  variables:
  - targetConfig: {fileID: 11400000, guid: d91345cba6825f74f8f0e8dabfb8cb5d, type: 2}
    fieldName: scentDecayTime
    min: 3
    max: 20
    defaultValue: 8
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: d91345cba6825f74f8f0e8dabfb8cb5d, type: 2}
    fieldName: scentSigma
    min: 0.5
    max: 3
    defaultValue: 1.5
    requiresRespawn: 0
    liveSync: 0
  sweepDuration: 10
