%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff60679b078f6a84cafb8f957d07cd55, type: 3}
  m_Name: 04_StepShape
  m_EditorClassIdentifier: Assembly-CSharp::TuningDimensionDef
  dimensionName: Step Shape
  testScenario: Walk slowly, then sprint. Watch arc height and cadence. High stepHeight
    = marching lift; low = shuffle. stepSpeedScale controls how much a sprint compresses
    step duration.
  variables:
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: stepHeight
    min: 1
    max: 12
    defaultValue: 4
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: baseStepDuration
    min: 0.05
    max: 0.5
    defaultValue: 0.2
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: minStepDuration
    min: 0.02
    max: 0.15
    defaultValue: 0.06
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: stepSpeedScale
    min: 0.05
    max: 1
    defaultValue: 0.3
    requiresRespawn: 0
    liveSync: 0
  sweepDuration: 10
