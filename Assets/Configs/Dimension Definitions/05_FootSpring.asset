%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff60679b078f6a84cafb8f957d07cd55, type: 3}
  m_Name: 05_FootSpring
  m_EditorClassIdentifier: Assembly-CSharp::TuningDimensionDef
  dimensionName: Foot Spring
  testScenario: Jump and watch feet tuck under body during arc. Land on platform
    and check for post-touch wobble. Lower footGroundDamping to see bounce then raise
    to kill it.
  variables:
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: footFrequency
    min: 3
    max: 25
    defaultValue: 12
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: footDampingRatio
    min: 0.2
    max: 1
    defaultValue: 0.7
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: footSpringMass
    min: 0.1
    max: 2
    defaultValue: 0.5
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: footGroundDamping
    min: 1
    max: 8
    defaultValue: 4
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: footAirDamping
    min: 0
    max: 2
    defaultValue: 0.5
    requiresRespawn: 0
    liveSync: 0
  sweepDuration: 10
