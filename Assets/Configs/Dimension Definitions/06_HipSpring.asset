MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff60679b078f6a84cafb8f957d07cd55, type: 3}
  m_Name: 06_HipSpring
  m_EditorClassIdentifier: Assembly-CSharp::TuningDimensionDef
  dimensionName: Hip Spring
  testScenario: Jump and land hard. Watch torso dip on landing and spring back. Drop
    from increasing heights to feel mass. Heavy hipMass causes stretch at jump start.
  variables:
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: hipFrequency
    min: 3
    max: 20
    defaultValue: 8
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: hipDampingRatio
    min: 0.2
    max: 1
    defaultValue: 0.7
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: hipMass
    min: 0.3
    max: 3
    defaultValue: 1
    requiresRespawn: 0
    liveSync: 0
  sweepDuration: 10
