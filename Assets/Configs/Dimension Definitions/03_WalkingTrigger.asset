  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff60679b078f6a84cafb8f957d07cd55, type: 3}
  m_Name: 03_WalkingTrigger
  m_EditorClassIdentifier: Assembly-CSharp::TuningDimensionDef
  dimensionName: Walking Trigger
  testScenario: Walk slowly and count step cadence. Sprint and watch foot placement
    ahead of body. Decelerate to stop and watch feet settle naturally.
  variables:
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: strideTriggerDistance
    min: 1
    max: 10
    defaultValue: 4
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: idleSpeedThreshold
    min: 0.1
    max: 1.5
    defaultValue: 0.5
    requiresRespawn: 0
    liveSync: 0
  - targetConfig: {fileID: 11400000, guid: bbd4678807967344096e2cb243566aa1, type: 2}
    fieldName: strideProjectionTime
    min: 0
    max: 0.35
    defaultValue: 0.12
    requiresRespawn: 0
    liveSync: 0
  sweepDuration: 10
